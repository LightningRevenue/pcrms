generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// A tenant. Each User belongs to exactly one Workspace (via WorkspaceMember, unique on userId) —
// no cross-workspace membership or workspace-switching yet. Add multi-workspace-per-user only
// if a real case (e.g. a consultant working two client workspaces) shows up.
//
// emailDomain is the company email domain that created this workspace (e.g. "acme.com") —
// the first sign-in from a domain creates the Workspace and claims it; every later sign-in
// from that same domain is blocked unless they arrive via a valid WorkspaceInvite, so
// teammates always land in one shared workspace instead of each minting their own.
model Workspace {
  id          String    @id @default(cuid())
  name        String
  industry    String?
  size        String? // "1-10" | "11-50" | "51-200" | "201-500" | "500+"
  emailDomain String    @unique
  createdAt   DateTime  @default(now())
  // Set by a platform admin (see User.isPlatformAdmin) to block every member's access —
  // checked in requireWorkspace(), null means active.
  suspendedAt DateTime?

  // Every workspace has a plan — new workspaces get whichever Plan has isDefault: true
  // (see ensureWorkspaceMembership in workspace.ts). Never null: entitlement checks
  // (src/lib/entitlements.ts) assume a plan always resolves.
  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  // Populated once Stripe billing is wired up (see BILLING integration point in
  // entitlements.ts / billing actions) — null until a workspace actually subscribes.
  // Until then every workspace just sits on whatever Plan an operator assigned manually.
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  members WorkspaceMember[]
  invites WorkspaceInvite[]

  companies              Company[]
  people                 Person[]
  activity               Activity[]
  tasks                  Task[]
  opportunities          Opportunity[]
  pipelineStages         PipelineStage[]
  emails                 Email[]
  emailOpportunities     EmailOpportunity[]
  taskOpportunities      TaskOpportunity[]
  emailTemplates         EmailTemplate[]
  playbooks              Playbook[]
  playbookSections       PlaybookSection[]
  customFieldDefinitions CustomFieldDefinition[]
  customFieldValues      CustomFieldValue[]
  importBatches          ImportBatch[]
  mailboxAccounts        MailboxAccount[]
  twilioAccount          TwilioAccount?
  calls                  Call[]
  userMailboxPreferences UserMailboxPreference[]
  workflows              Workflow[]
  dashboards             Dashboard[]
  emailOpens             EmailOpen[]
  notes                  Note[]
  noteOpportunities      NoteOpportunity[]
  campaigns              Campaign[]
  campaignMailboxes      CampaignMailbox[]
  campaignMembers        CampaignMember[]
  sequences              Sequence[]
  sequenceSteps          SequenceStep[]
  sequenceEnrollments    SequenceEnrollment[]
  sequenceStepRuns       SequenceStepRun[]
  lists                  List[]
  listItems              ListItem[]
  favorites              Favorite[]
  notifications          Notification[]
  settings               WorkspaceSetting[]
}

// A subscription tier (e.g. Free/Pro/Enterprise — names/pricing decided later, not here).
// Deliberately holds no pricing/Stripe fields itself; a Plan is just a named bundle of
// PlanLimit rows. Exactly one Plan must have isDefault: true at any time — that's what new
// workspaces land on (see ensureWorkspaceMembership in workspace.ts).
model Plan {
  id        String   @id @default(cuid())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  // Null for the free/default plan (nothing to check out for) or any plan not yet linked to
  // a real Stripe Price — set from /admin/plans once the matching Price exists in Stripe.
  // Checkout (src/lib/actions/checkout.ts) refuses to start for a plan with no price set.
  stripePriceId String? @unique

  limits     PlanLimit[]
  workspaces Workspace[]
}

// One row per (plan, entitlement key). `key` must match an entry in the ENTITLEMENTS
// registry (src/lib/entitlements.ts) — that registry is the single source of truth for
// which keys exist, what they mean, and how "count" keys are measured; this table only
// holds the numbers/flags per plan. A missing row for a given (planId, key) means
// unlimited/enabled — see resolveLimit() in entitlements.ts.
//
// `value` doubles as the count cap (type: "count"/"monthly") and the on/off flag
// (type: "feature", where 0 = disabled, any nonzero = enabled) so adding a new
// entitlement never requires a schema change, only a new ENTITLEMENTS registry entry.
model PlanLimit {
  id    String @id @default(cuid())
  key   String
  value Int? // null = unlimited (count/monthly) or enabled (feature, when the row exists at all)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  role        String    @default("member") // "owner" | "member"
  onboardedAt DateTime?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// A pending invitation to join an existing Workspace, sent by an owner/member to a specific
// email address. Consumed at sign-in: if a matching, unexpired, unconsumed invite exists for
// the signing-in email, the user joins that Workspace instead of being blocked by the
// "domain already has a workspace" rule (see Workspace.emailDomain) or minting a new one.
model WorkspaceInvite {
  id         String    @id @default(cuid())
  email      String
  role       String    @default("member") // "owner" | "member"
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invitedById String?
  invitedBy   User?   @relation(fields: [invitedById], references: [id])

  @@index([workspaceId])
  @@index([email])
}

// Auth.js required models — https://authjs.dev/getting-started/adapters/prisma
model User {
  id                   String                  @id @default(cuid())
  name                 String?
  email                String?                 @unique
  emailVerified        DateTime?
  image                String?
  firstName            String?
  lastName             String?
  personalEmail        String?
  phone                String?
  website              String?
  title                String?
  company              String?
  // Only set for accounts created via the email+password (Credentials) flow — bcrypt hash,
  // never the raw password. Google-only accounts have no password and can't use Credentials sign-in.
  passwordHash         String?
  // Grants access to /admin (platform-wide operator console — list/suspend workspaces, etc.),
  // completely separate from WorkspaceMember.role: a platform admin isn't necessarily a member
  // of any workspace at all. Set manually in the DB, not through any UI — there's no self-serve
  // path to becoming one.
  isPlatformAdmin      Boolean                 @default(false)
  workspaceMember      WorkspaceMember?
  sentInvites          WorkspaceInvite[]
  accounts             Account[]
  sessions             Session[]
  people               Person[]                @relation("PersonCreatedBy")
  ownedPeople          Person[]                @relation("PersonOwner")
  companies            Company[]
  activity             Activity[]
  sentEmails           Email[]
  emailTemplates       EmailTemplate[]
  notifications        Notification[]
  workflows            Workflow[]
  importBatches        ImportBatch[]
  tasks                Task[]
  ownedOpportunities   Opportunity[]           @relation("OpportunityOwner")
  createdOpportunities Opportunity[]           @relation("OpportunityCreatedBy")
  notes                Note[]
  sequences            Sequence[]
  sequenceEnrollments  SequenceEnrollment[]
  favorites            Favorite[]
  mailboxAccounts      MailboxAccount[]
  lists                List[]
  mailboxPreferences   UserMailboxPreference[]
  campaigns            Campaign[]
  campaignMembers      CampaignMember[]
  twilioAccountUpdates TwilioAccount[]
  calls                Call[]
  playbooks            Playbook[]
}

// Per-user favorites (Home sidebar shortcut), capped at 5 per user — enforced in the action, not the schema.
model Favorite {
  id         String   @id @default(cuid())
  entityType String // "company" | "person" | "opportunity"
  entityId   String
  name       String
  href       String
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
  @@index([userId, createdAt])
  @@index([workspaceId])
}

// A List holds one entity type only (fixed at creation). Membership rows (ListItem)
// are polymorphic like Favorite — entityId points into Company/Person/Opportunity
// depending on the parent List's entityType, validated in the action layer, not the schema.
model List {
  id         String   @id @default(cuid())
  name       String
  entityType String // "company" | "person" | "opportunity"
  createdAt  DateTime @default(now())

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  items ListItem[]

  @@index([workspaceId])
}

model ListItem {
  id       String   @id @default(cuid())
  entityId String
  addedAt  DateTime @default(now())

  listId String
  list   List   @relation(fields: [listId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([listId, entityId])
  @@index([listId])
  @@index([workspaceId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// CRM models — Company/Person/Opportunity CRUD comes next
model Company {
  id            String    @id @default(cuid())
  name          String
  domain        String?
  address       String?
  linkedin      String?
  annualRevenue String?
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  people        Person[]
  opportunities Opportunity[]

  @@index([workspaceId])
  @@index([deletedAt])
}

model Person {
  id        String    @id @default(cuid())
  firstName String
  lastName  String?
  email     String?
  phone     String?
  jobTitle  String?
  linkedin  String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdById String?
  createdBy   User?   @relation("PersonCreatedBy", fields: [createdById], references: [id])

  ownerId String?
  owner   User?   @relation("PersonOwner", fields: [ownerId], references: [id])

  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  opportunities       Opportunity[]
  emails              Email[]
  tasks               Task[]
  notes               Note[]
  sequenceEnrollments SequenceEnrollment[]
  campaignMembers     CampaignMember[]
  calls               Call[]

  @@index([workspaceId])
  @@index([deletedAt])
}

// Unified activity log for Person/Company/Opportunity timelines. entityId is not a
// relation (rows can outlive their entity being deleted) so nothing cascades from here.
model Activity {
  id         String   @id @default(cuid())
  entityType String // "person" | "company" | "opportunity"
  entityId   String
  kind       String   @default("field_update") // "created" | "field_update" | "opportunity_created" | "stage_changed" | "task_created" | "task_completed" | "email_sent" | "person_removed" | "company_removed"
  field      String?
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId, createdAt])
  @@index([workspaceId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("general") // "call" | "email" | "event" | "meet" | "general"
  priority    String    @default("medium") // "low" | "medium" | "high"
  dueAt       DateTime?
  done        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  opportunities TaskOpportunity[]

  @@index([personId])
  @@index([workspaceId])
}

model Opportunity {
  id        String    @id @default(cuid())
  name      String
  value     Int       @default(0)
  stage     String    @default("New")
  closeDate DateTime?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  contactId String?
  contact   Person? @relation(fields: [contactId], references: [id])

  ownerId String?
  owner   User?   @relation("OpportunityOwner", fields: [ownerId], references: [id])

  createdById String?
  createdBy   User?   @relation("OpportunityCreatedBy", fields: [createdById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  emails EmailOpportunity[]
  tasks  TaskOpportunity[]
  notes  NoteOpportunity[]

  @@index([workspaceId])
  @@index([deletedAt])
}

model PipelineStage {
  id        String   @id @default(cuid())
  label     String
  order     Int      @default(0)
  outcome   String   @default("open") // "open" | "won" | "lost"
  createdAt DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, label])
}

model Email {
  id              String   @id @default(cuid())
  gmailMessageId  String?  @unique
  gmailThreadId   String?
  messageIdHeader String?
  // Message-ID this one replies to (In-Reply-To header) — used to thread SMTP/IMAP mail,
  // which has no gmailThreadId, by walking the reply chain back to its root.
  inReplyTo       String?
  direction       String // "sent" | "received"
  from            String
  to              String[]
  cc              String[]
  bcc             String[]
  subject         String
  bodyHtml        String
  sentAt          DateTime @default(now())
  createdAt       DateTime @default(now())

  // Null when the message came in over IMAP from an address not recognized as a CRM contact.
  personId String?
  person   Person? @relation(fields: [personId], references: [id], onDelete: Cascade)

  senderId String?
  sender   User?   @relation(fields: [senderId], references: [id])

  // Set when synced/sent via an Outreach Inbox (SMTP/IMAP) rather than the Gmail OAuth account.
  mailboxAccountId String?
  mailboxAccount   MailboxAccount? @relation(fields: [mailboxAccountId], references: [id], onDelete: SetNull)
  // IMAP UIDs are only unique per-mailbox, so uniqueness is scoped to mailboxAccountId — dedupes polling.
  imapUid          Int?

  // Set when this email was a campaign send — lets the campaign dashboard roll up opens
  // without guessing which Email row belongs to which campaign member.
  campaignMemberId String?
  campaignMember   CampaignMember? @relation(fields: [campaignMemberId], references: [id], onDelete: SetNull)

  opens         EmailOpen[]
  opportunities EmailOpportunity[]

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([mailboxAccountId, imapUid])
  @@index([personId])
  @@index([gmailThreadId])
  @@index([workspaceId])
}

model EmailOpportunity {
  emailId       String
  email         Email       @relation(fields: [emailId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([emailId, opportunityId])
  @@index([opportunityId])
  @@index([workspaceId])
}

model TaskOpportunity {
  taskId        String
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([taskId, opportunityId])
  @@index([opportunityId])
  @@index([workspaceId])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  bodyHtml  String
  createdAt DateTime @default(now())

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  sequenceSteps SequenceStep[]
  campaigns     Campaign[]

  @@index([workspaceId])
}

model Playbook {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  sections PlaybookSection[]

  @@index([workspaceId])
}

model PlaybookSection {
  id       String @id @default(cuid())
  title    String
  body     String
  position Int

  playbookId String
  playbook   Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([playbookId])
  @@index([workspaceId])
}

model CronJobRun {
  id          String    @id @default(cuid())
  job         String // "gmail-reply-sync"
  status      String // "success" | "error" | "running"
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  emailsFound Int       @default(0)
  error       String?

  @@index([job, startedAt])
}

model CustomFieldDefinition {
  id         String   @id @default(cuid())
  objectType String // "company" | "person"
  key        String
  label      String
  type       String   @default("TEXT") // "TEXT" | "NUMBER" | "DATE" | "SELECT"
  options    String[] @default([]) // choices, only used when type = "SELECT"
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  values CustomFieldValue[]

  @@unique([workspaceId, objectType, key])
}

model CustomFieldValue {
  id        String   @id @default(cuid())
  recordId  String
  value     String?
  updatedAt DateTime @updatedAt

  definitionId String
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([definitionId, recordId])
  @@index([recordId])
  @@index([workspaceId])
}

model ImportBatch {
  id          String   @id @default(cuid())
  name        String
  objectType  String // "company" | "person"
  status      String   @default("pending") // "pending" | "processing" | "done" | "failed"
  totalRows   Int      @default(0)
  successRows Int      @default(0)
  errorRows   Int      @default(0)
  errors      Json?
  createdAt   DateTime @default(now())

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  companies Company[]
  people    Person[]

  @@index([workspaceId])
}

model Notification {
  id        String   @id @default(cuid())
  kind      String // "email_reply"
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([workspaceId])
}

// Outreach mailbox connected via raw SMTP/IMAP creds (no OAuth) — used for sending sequence
// emails from an inbox other than the user's connected Gmail. Rules/scheduling not built yet.
model MailboxAccount {
  id        String   @id @default(cuid())
  label     String
  email     String
  smtpHost  String
  smtpPort  Int      @default(587)
  imapHost  String
  imapPort  Int      @default(993)
  username  String
  // ponytail: stored plain, no secrets vault wired up yet. Encrypt at rest before handling real customer creds.
  password  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  // Last connection check result, set by checkMailboxAccount — not a scheduled/background check.
  smtpStatus    String? // "ok" | "error"
  smtpError     String?
  imapStatus    String? // "ok" | "error"
  imapError     String?
  lastCheckedAt DateTime?

  // High-water mark for IMAP polling — only UIDs above this have been fetched into Email rows.
  imapLastUid Int @default(0)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  emails          Email[]
  defaultForUsers UserMailboxPreference[]
  campaigns       CampaignMailbox[]

  @@index([createdById])
  @@index([workspaceId])
}

// Workspace-wide Twilio Voice credentials — one row per Workspace (was a single
// hardcoded id: "default" row pre-multi-tenancy), not per-user, since calls go out
// from one shared Twilio number per workspace. Configured in Settings > Accounts >
// Twilio instead of env vars so it can be rotated without a redeploy.
//
// accountSid/authToken/phoneNumber authenticate server-side REST calls (placing
// calls, fetching recordings). apiKeySid/apiKeySecret + twimlAppSid are the
// separate credential pair the browser-side Voice SDK needs: the server mints a
// short-lived access token (signed with the API key) that the browser uses to
// register with Twilio and place a WebRTC call through the TwiML App, which
// points at this app's /api/twilio/voice webhook.
model TwilioAccount {
  id          String @id @default(cuid())
  accountSid  String
  // ponytail: stored plain, no secrets vault wired up yet — same tradeoff as MailboxAccount.password.
  authToken   String
  phoneNumber String

  apiKeySid    String?
  apiKeySecret String?
  twimlAppSid  String?

  updatedAt DateTime @updatedAt

  updatedById String?
  updatedBy   User?   @relation(fields: [updatedById], references: [id])

  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// One row per browser-initiated call. Created when the agent clicks "Call" and
// the client requests an access token (status "initiated"), then updated by the
// /api/twilio/voice-status webhook as Twilio reports status changes, and again
// by /api/twilio/recording-status once the recording is ready.
model Call {
  id            String    @id @default(cuid())
  twilioCallSid String?   @unique
  direction     String    @default("outbound") // "outbound" — inbound calls aren't handled yet
  status        String    @default("initiated") // "initiated" | "ringing" | "in-progress" | "completed" | "failed" | "no-answer" | "busy"
  toNumber      String
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  durationSec   Int?

  recordingSid         String?
  recordingUrl         String?
  recordingDurationSec Int?

  personId String?
  person   Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([twilioCallSid])
  @@index([workspaceId])
}

// A user's chosen set of "my mailboxes" among the connected outreach inboxes — surfaced in
// Settings > General so a user can scope which SMTP/IMAP accounts they send from by default,
// out of every mailbox the workspace has connected. Many-to-many: a mailbox can be picked by
// several users, and a user can pick several mailboxes.
model UserMailboxPreference {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mailboxAccountId String
  mailboxAccount   MailboxAccount @relation(fields: [mailboxAccountId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, mailboxAccountId])
  @@index([mailboxAccountId])
  @@index([workspaceId])
}

// Key-value settings, some genuinely global (app_base_url, tracking_domain — this app runs
// on one domain regardless of workspace) and some per-workspace (notification_inbox — which
// mailbox sends a given workspace's internal CRM notifications). workspaceId is null for the
// global ones; @@unique([workspaceId, key]) lets both null (global) and per-workspace rows
// coexist under the same key without colliding — Postgres treats each NULL as distinct for
// uniqueness, so multiple workspaces can each have their own "notification_inbox" row.
model WorkspaceSetting {
  id    String @id @default(cuid())
  key   String
  value String

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  active      Boolean  @default(false)
  triggerType String?
  createdAt   DateTime @default(now())

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// One row per built-in dashboard view. `kind` selects which hardcoded stats
// query/component the page renders — dashboards aren't user-built yet, so this
// is a thin lookup table (name + ordering), not a report-builder schema.
model Dashboard {
  id        String   @id @default(cuid())
  name      String
  kind      String // "sales-tracking" — maps to a specific dashboard view
  order     Int      @default(0)
  createdAt DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, kind])
}

model EmailOpen {
  id        String   @id @default(cuid())
  openedAt  DateTime @default(now())
  ip        String?
  userAgent String?

  emailId String
  email   Email  @relation(fields: [emailId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@index([workspaceId])
}

model Note {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  opportunities NoteOpportunity[]

  @@index([personId])
  @@index([workspaceId])
}

model NoteOpportunity {
  noteId        String
  note          Note        @relation(fields: [noteId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([noteId, opportunityId])
  @@index([opportunityId])
  @@index([workspaceId])
}

// A bulk-email campaign: a one-off send to a static set of people, as opposed to a
// Sequence's multi-step drip. Membership is captured at build time (CampaignMember),
// not re-evaluated later — adding someone to a Sequence/other Campaign after the fact
// doesn't retroactively remove them.
model Campaign {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("draft") // "draft" | "active" | "sent"
  createdAt DateTime @default(now())

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  // Subject/body are interpolated per-recipient at send time via interpolateForPerson,
  // same {{person.x}} / {{company.x}} tokens as Sequence steps.
  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  members   CampaignMember[]
  mailboxes CampaignMailbox[]

  @@index([workspaceId])
}

model CampaignMailbox {
  id      String   @id @default(cuid())
  addedAt DateTime @default(now())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  mailboxAccountId String
  mailboxAccount   MailboxAccount @relation(fields: [mailboxAccountId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([campaignId, mailboxAccountId])
  @@index([mailboxAccountId])
  @@index([workspaceId])
}

model CampaignMember {
  id      String   @id @default(cuid())
  addedAt DateTime @default(now())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  // Set when the member was pulled in via a Deal rather than picked directly from Contacts.
  viaOpportunityId String?

  addedById String?
  addedBy   User?   @relation(fields: [addedById], references: [id])

  // Per-recipient send state, set once startCampaign enqueues the paced send jobs.
  sendStatus String    @default("pending") // "pending" | "queued" | "sent" | "failed"
  sentAt     DateTime?
  sendError  String?

  emails Email[]

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([campaignId, personId])
  @@index([personId])
  @@index([workspaceId])
}

model Sequence {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  @@index([workspaceId])
}

model SequenceStep {
  id    String @id @default(cuid())
  order Int    @default(0)
  type  String // "email" | "task" | "note"

  // Delay from enrollment start (cumulative, not from previous step).
  delayDays  Int @default(0)
  delayHours Int @default(0)

  // type: "email" — either templateId (send template as-is, still interpolated) or
  // subject/bodyHtml for a custom-written step. Never both meaningfully used at once.
  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id])
  subject    String?
  bodyHtml   String?

  // type: "task"
  taskTitle       String?
  taskDescription String?
  taskType        String? // "call" | "email" | "event" | "meet" | "general"
  taskPriority    String? // "low" | "medium" | "high"

  // type: "note"
  noteBody String?

  sequenceId String
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  runs SequenceStepRun[]

  @@index([sequenceId, order])
  @@index([workspaceId])
}

model SequenceEnrollment {
  id          String    @id @default(cuid())
  status      String    @default("active") // "active" | "completed" | "cancelled"
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  sequenceId String
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  enrolledById String?
  enrolledBy   User?   @relation(fields: [enrolledById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  runs SequenceStepRun[]

  @@unique([sequenceId, personId])
  @@index([personId])
  @@index([workspaceId])
}

model SequenceStepRun {
  id           String    @id @default(cuid())
  status       String    @default("pending") // "pending" | "sent" | "failed" | "skipped"
  scheduledFor DateTime
  executedAt   DateTime?
  error        String?

  enrollmentId String
  enrollment   SequenceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  stepId String
  step   SequenceStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, stepId])
  @@index([status, scheduledFor])
  @@index([workspaceId])
}
